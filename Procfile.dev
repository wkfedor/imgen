redis: sh -c 'if redis-cli -p 6380 ping >/dev/null 2>&1; then echo "Redis already running on port 6380, using existing instance"; tail -f /dev/null; else exec redis-server --port 6380 --save "" --appendonly no; fi'
web: sh -c 'if [ -f tmp/pids/server.pid ] && kill -0 $(cat tmp/pids/server.pid) >/dev/null 2>&1; then echo "Rails server already running with pid $(cat tmp/pids/server.pid), using existing instance"; tail -f /dev/null; else rm -f tmp/pids/server.pid; REDIS_URL=redis://127.0.0.1:6380/0 exec ruby -S bundle _2.4.22_ exec rails server -b 127.0.0.1 -p ${PORT:-4567}; fi'
worker: REDIS_URL=redis://127.0.0.1:6380/0 ruby -S bundle _2.4.22_ exec sidekiq -q comfy_generation -c 1 -q imgen
