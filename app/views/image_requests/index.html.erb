<section class="hero">
  <div>
    <h1>Imgen Comparator</h1>
    <p>Один промпт отправляется в Sidekiq-очередь и последовательно генерируется на выбранных моделях ComfyUI.</p>
  </div>
  <div class="request-actions">
    <a class="sidekiq-link" href="/sidekiq">Sidekiq</a>
    <%= button_to "Удалить все промпты", destroy_all_image_requests_path, method: :delete, form: { class: "delete-request-form", onsubmit: "return confirm('Удалить ВСЕ промпты и все картинки локально и с сервера ComfyUI?')" }, class: "delete-request-button" %>
  </div>
</section>

<% if notice.present? %><p class="flash"><%= notice %></p><% end %>
<% if alert.present? %><p class="flash flash-alert"><%= alert %></p><% end %>

<section class="panel">
  <div class="panel-head">
    <h2>Новый запрос</h2>
    <button type="button" id="refresh-models">Обновить модели</button>
  </div>
  <% if @model_error.present? %>
    <p class="flash flash-alert">Не удалось получить модели: <%= @model_error %></p>
  <% end %>
  <%= form_with url: image_requests_path, method: :post, local: true, class: "prompt-form" do %>
    <textarea name="prompt" rows="5" required placeholder="cozy isometric Toca Boca style playroom, colorful furniture, empty floor area for placing game objects, soft light, high detail"></textarea>
    <div class="generation-settings">
      <label>
        <span>Width</span>
        <input type="number" name="width" min="128" max="1536" step="64" value="768">
      </label>
      <label>
        <span>Height</span>
        <input type="number" name="height" min="128" max="1536" step="64" value="1344">
      </label>
      <label>
        <span>Steps</span>
        <input type="number" name="steps" min="1" max="80" step="1" value="60">
      </label>
    </div>
    <fieldset>
      <legend>Модели на сервере</legend>
      <div id="model-list" class="models" data-autoload="true">
        <% @models.each do |model| %>
          <label class="model-check">
            <input type="checkbox" name="models[]" value="<%= model %>" checked>
            <span><%= model %></span>
          </label>
        <% end %>
        <% if @models.empty? %>
          <p class="muted">Модели загрузятся отдельным запросом. Если список пустой, нажмите «Обновить модели».</p>
        <% end %>
      </div>
    </fieldset>
    <button type="submit">Добавить в очередь</button>
  <% end %>
</section>

<section class="panel">
  <h2>Очередь и результаты</h2>
  <div class="requests" id="requests">
    <% @image_requests.each do |request| %>
      <article class="request" id="request-<%= request.id %>" data-request-id="<%= request.id %>">
        <div class="request-head">
          <strong>#<%= request.id %> · <span class="request-status"><%= request.status %></span><% if request.api_source? %> · <span class="source-badge">api</span><% end %></strong>
          <div class="request-actions">
            <span><%= request.created_at.strftime("%Y-%m-%d %H:%M:%S") %></span>
            <%= button_to "Удалить промпт", image_request_path(request), method: :delete, form: { class: "delete-request-form", onsubmit: "return confirm('Удалить промпт и все его картинки локально и с сервера ComfyUI?')" }, class: "delete-request-button" %>
          </div>
        </div>
        <p class="prompt"><%= request.prompt %></p>
        <p class="request-settings"><%= request.width %>x<%= request.height %>, <%= request.steps %> steps</p>
        <% if request.error_message.present? %>
          <pre class="error"><%= request.error_message %></pre>
        <% end %>
        <button type="button" class="load-results-button" data-load-results>Показать картинки</button>
        <div class="results" data-loaded="false">
          <div class="placeholder">детали загрузятся отдельно</div>
        </div>
        <% if request.failed? %>
          <details class="inline-run-form">
            <summary>Повторить весь промпт с параметрами</summary>
            <%= form_with url: retry_image_request_path(request), method: :post, local: true, class: "retry-form regenerate-form" do %>
              <label>
                <span>Промпт</span>
                <textarea name="prompt" rows="5"><%= request.prompt %></textarea>
              </label>
              <div class="generation-settings">
                <label><span>Width</span><input type="number" name="width" min="128" max="1536" step="64" value="<%= request.width %>"></label>
                <label><span>Height</span><input type="number" name="height" min="128" max="1536" step="64" value="<%= request.height %>"></label>
                <label><span>Steps</span><input type="number" name="steps" min="1" max="80" step="1" value="<%= request.steps %>"></label>
              </div>
              <button type="submit">Повторить</button>
            <% end %>
          </details>
        <% end %>
      </article>
    <% end %>
  </div>
</section>

<script>
  (() => {
    const terminalStatuses = new Set(["completed", "failed", "deleted"]);

    function escapeHtml(value) {
      return String(value ?? "").replace(/[&<>"]/g, (char) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[char]));
    }

    function renderResult(result) {
      const classes = `result-card status-${escapeHtml(result.status)}`;
      const csrfToken = document.querySelector('meta[name="csrf-token"]')?.content || "";
      const prompt = escapeHtml(result.actual_prompt);
      const regenerateForm = `
        <form class="button_to retry-form regenerate-form" method="post" action="${escapeHtml(result.regenerate_url)}">
          <input type="hidden" name="authenticity_token" value="${escapeHtml(csrfToken)}" autocomplete="off">
          <label>
            <span>Промпт</span>
            <textarea name="prompt" rows="3">${prompt}</textarea>
          </label>
          <div class="generation-settings">
            <label><span>Width</span><input type="number" name="width" min="128" max="1536" step="64" value="${escapeHtml(result.width)}"></label>
            <label><span>Height</span><input type="number" name="height" min="128" max="1536" step="64" value="${escapeHtml(result.height)}"></label>
            <label><span>Steps</span><input type="number" name="steps" min="1" max="80" step="1" value="${escapeHtml(result.steps)}"></label>
          </div>
          <button type="submit">Перегенерить</button>
        </form>`;
      let body = "";
      if (result.image_url) {
        body = `
          <a href="${escapeHtml(result.image_url)}" target="_blank" rel="noopener">
            <img src="${escapeHtml(result.image_url)}" alt="${escapeHtml(result.checkpoint_name)}">
          </a>
          <small>seed ${escapeHtml(result.seed)}, ${escapeHtml(result.duration_sec)} сек</small>
          <details class="actual-prompt">
            <summary>Промпт, реально отправленный в ИИ</summary>
            <p>${escapeHtml(result.actual_prompt)}</p>
          </details>
          ${regenerateForm}`;
      } else if (result.error_message) {
        body = `<pre class="error">${escapeHtml(result.error_message)}</pre>
          ${regenerateForm}`;
      } else if (result.status === "deleted") {
        body = `<div class="placeholder">удалена</div>
          ${regenerateForm}`;
      } else {
        body = `<div class="placeholder">ожидает</div>`;
      }

      return `
        <div class="${classes}" data-result-id="${escapeHtml(result.id)}">
          <h3>${escapeHtml(result.checkpoint_name)}</h3>
          <p class="result-status">${escapeHtml(result.status)}</p>
          <p class="request-settings">${escapeHtml(result.width)}x${escapeHtml(result.height)}, ${escapeHtml(result.steps)} steps</p>
          ${body}
        </div>`;
    }

    function updateRequest(article, data) {
      article.querySelector(".request-status").textContent = data.status;
      const results = article.querySelector(".results");
      results.innerHTML = "";

      data.results.forEach((result) => {
        const existing = results.querySelector(`[data-result-id="${CSS.escape(String(result.id))}"]`);
        const rendered = renderResult(result).trim();
        if (!existing) {
          results.insertAdjacentHTML("beforeend", rendered);
          return;
        }

        const previousState = existing.dataset.renderState || "";
        const nextState = JSON.stringify({
          status: result.status,
          error_message: result.error_message,
          image_url: result.image_url,
          seed: result.seed,
          duration_sec: result.duration_sec,
          width: result.width,
          height: result.height,
          steps: result.steps,
          actual_prompt: result.actual_prompt
        });

        if (previousState !== nextState) {
          existing.outerHTML = rendered;
          const updated = results.querySelector(`[data-result-id="${CSS.escape(String(result.id))}"]`);
          if (updated) updated.dataset.renderState = nextState;
        }
      });

      return terminalStatuses.has(data.status) && data.results.every((result) => terminalStatuses.has(result.status));
    }

    async function loadRequestDetails(article) {
      const requestId = article.dataset.requestId;
      if (!requestId) return;

      const button = article.querySelector("[data-load-results]");
      if (button) button.disabled = true;
      try {
        const response = await fetch(`/api/v1/image_requests/statuses?ids=${encodeURIComponent(requestId)}`, { headers: { Accept: "application/json" } });
        if (!response.ok) return;

        const body = await response.json();
        const request = body.data.requests[0];
        if (!request) return;

        updateRequest(article, request);
        article.querySelector(".results").dataset.loaded = "true";
      } finally {
        if (button) button.disabled = false;
      }
    }

    async function refreshActiveRequests() {
      const active = Array.from(document.querySelectorAll(".request")).filter((article) => {
        const status = article.querySelector(".request-status")?.textContent?.trim();
        const resultsLoaded = article.querySelector(".results")?.dataset.loaded === "true";
        return status && !terminalStatuses.has(status) && !resultsLoaded;
      });

      if (active.length === 0) return;
      const ids = active.map((article) => article.dataset.requestId).filter(Boolean);
      const response = await fetch(`/api/v1/image_requests/statuses?ids=${encodeURIComponent(ids.join(","))}`, { headers: { Accept: "application/json" } });
      if (response.ok) {
        const body = await response.json();
        const byId = new Map(active.map((article) => [Number(article.dataset.requestId), article]));
        body.data.requests.forEach((request) => {
          const article = byId.get(Number(request.id));
          if (article) {
            updateRequest(article, request);
            article.querySelector(".results").dataset.loaded = "true";
          }
        });
      }

      const delay = active.length > 50 ? 30000 : active.length > 10 ? 10000 : 5000;
      window.setTimeout(refreshActiveRequests, delay);
    }

    document.addEventListener("click", (event) => {
      const button = event.target.closest("[data-load-results]");
      if (!button) return;

      const article = button.closest(".request");
      if (article) loadRequestDetails(article);
    });

    window.setTimeout(refreshActiveRequests, 1500);
  })();
</script>
